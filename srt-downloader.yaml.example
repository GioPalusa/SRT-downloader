# Example configuration file for SRT Downloader

# Folder to scan. Defaults to the current directory when omitted.
path: .

# Languages are tried in order. English is appended automatically if not present.
languages:
  - sv
  - en

# Optional preferred provider order. Public fallback providers are appended unless disabled.
selected_providers:
  - opensubtitlescom

# Optional provider credentials.
providers:
  opensubtitlescom:
    username: your_username
    password: your_password
  addic7ed:
    username: your_username
    password: your_password

# Restrict the run to only selected and credentialed providers.
only_selected_providers: false

# Slower, but shows provider-by-provider progress.
detailed_progress: false

# Enable debug logging.
verbose: false

# Subtitle file encoding.
encoding: utf-8